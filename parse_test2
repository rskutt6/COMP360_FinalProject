#lang racket

(require brag/support
         "lexer.rkt"
         "parser.rkt")

(define str
  "(room wake
     (desc \"You wake up underwater\")
     (exit east kelp))")

(define in (open-input-string str))

(define next-token
  (λ () (dungeon-lexer in)))

(define tree
  (parse next-token))

(displayln (syntax->datum tree))
